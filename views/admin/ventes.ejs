<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-admin') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-cash-coin me-2"></i><%= title %></h4>
        <div class="d-flex gap-2">
            <a href="/admin/ventes" class="btn <%= periode === 'tous' ? 'btn-success' : 'btn-outline-success' %> btn-sm">Tout</a>
            <a href="/admin/ventes?periode=jour" class="btn <%= periode === 'jour' ? 'btn-success' : 'btn-outline-success' %> btn-sm">Aujourd'hui</a>
            <a href="/admin/ventes?periode=hebdo" class="btn <%= periode === 'hebdo' ? 'btn-success' : 'btn-outline-success' %> btn-sm">7 jours</a>
        </div>
    </div>

    <!-- Totaux -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card" style="background:linear-gradient(135deg,#16a34a,#15803d);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= totaux.nb_ventes || 0 %></div><div>Nombre de ventes</div></div>
                    <i class="bi bi-receipt stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number" style="font-size:1.3rem"><%= parseFloat(totaux.ca_total).toLocaleString('fr-FR') %></div><div>CA total (FCFA)</div></div>
                    <i class="bi bi-cash-stack stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <% if (ventes.length === 0) { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>Aucune vente sur cette période
                </div>
            <% } else { %>
            <table class="table table-hover mb-0">
                <thead style="background:#064e3b; color:white;">
                    <tr>
                        <th class="px-4 py-3">Référence</th>
                        <th>Vendeur</th>
                        <th>Articles</th>
                        <th>Montant total</th>
                        <th>Montant reçu</th>
                        <th>Monnaie rendue</th>
                        <th>Date & Heure</th>
                    </tr>
                </thead>
                <tbody>
                <% ventes.forEach(v => { %>
                    <tr>
                        <td class="px-4 fw-semibold"><%= v.reference %></td>
                        <td><%= v.vendeur_prenom ? v.vendeur_prenom + ' ' + v.vendeur_nom : 'Boutique' %></td>
                        <td><span class="badge bg-secondary"><%= v.nb_articles %></span></td>
                        <td><strong class="text-success"><%= parseFloat(v.montant_total).toLocaleString('fr-FR') %> FCFA</strong></td>
                        <td><%= parseFloat(v.montant_recu).toLocaleString('fr-FR') %> FCFA</td>
                        <td><span class="badge bg-warning text-dark"><%= parseFloat(v.monnaie_rendue).toLocaleString('fr-FR') %> FCFA</span></td>
                        <td><%= new Date(v.date_vente).toLocaleString('fr-FR') %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
