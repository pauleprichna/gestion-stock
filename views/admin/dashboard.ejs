<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-admin') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-speedometer2 me-2"></i>Tableau de bord — Administrateur</h4>
        <span class="badge" style="background:#064e3b; padding:8px 15px; border-radius:20px;">
            <i class="bi bi-shield-check me-1"></i>Administrateur
        </span>
    </div>

    <p class="text-muted fw-semibold mb-2"><i class="bi bi-people me-2"></i>Système</p>
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#16a34a,#15803d);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.utilisateurs || 0 %></div><div>Utilisateurs</div></div>
                    <i class="bi bi-people-fill stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.produits || 0 %></div><div>Produits</div></div>
                    <i class="bi bi-box-seam stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.categories || 0 %></div><div>Catégories</div></div>
                    <i class="bi bi-tags-fill stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#dc2626,#b91c1c);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.alertes || 0 %></div><div>Alertes stock</div></div>
                    <i class="bi bi-exclamation-triangle-fill stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <p class="text-muted fw-semibold mb-2"><i class="bi bi-cash-coin me-2"></i>Ventes</p>
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#0891b2,#0e7490);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.ventesJour || 0 %></div><div>Ventes aujourd'hui</div></div>
                    <i class="bi bi-bag-check-fill stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#16a34a,#064e3b);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number" style="font-size:1.2rem"><%= stats.caJour || 0 %></div><div>CA aujourd'hui (FCFA)</div></div>
                    <i class="bi bi-cash-stack stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#db2777,#be185d);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.ventesHebdo || 0 %></div><div>Ventes 7 jours</div></div>
                    <i class="bi bi-receipt stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#047857,#065f46);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number" style="font-size:1.2rem"><%= stats.caHebdo || 0 %></div><div>CA 7 jours (FCFA)</div></div>
                    <i class="bi bi-graph-up-arrow stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header" style="background:#064e3b; color:white;">
            <i class="bi bi-lightning-charge-fill me-2"></i>Accès rapides
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <a href="/admin/utilisateurs" class="btn btn-outline-success w-100 py-3">
                        <i class="bi bi-people-fill d-block fs-3 mb-2"></i>Utilisateurs</a>
                </div>
                <div class="col-md-3">
                    <a href="/admin/ventes?periode=jour" class="btn btn-outline-warning w-100 py-3">
                        <i class="bi bi-cash-coin d-block fs-3 mb-2"></i>Ventes du jour</a>
                </div>
                <div class="col-md-3">
                    <a href="/admin/stock" class="btn btn-outline-danger w-100 py-3">
                        <i class="bi bi-boxes d-block fs-3 mb-2"></i>État du stock</a>
                </div>
                <div class="col-md-3">
                    <a href="/admin/fournisseurs" class="btn btn-outline-secondary w-100 py-3">
                        <i class="bi bi-truck d-block fs-3 mb-2"></i>Fournisseurs</a>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
