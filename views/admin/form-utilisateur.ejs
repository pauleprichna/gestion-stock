<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-admin') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-person-fill me-2"></i><%= utilisateur ? 'Modifier' : 'Nouvel' %> Utilisateur</h4>
        <a href="/admin/utilisateurs" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Retour</a>
    </div>

    <div class="card" style="max-width:600px;">
        <div class="card-header" style="background:#064e3b; color:white;">
            <i class="bi bi-person-fill me-2"></i>Informations de l'utilisateur
        </div>
        <div class="card-body p-4">
            <form action="<%= utilisateur ? '/admin/utilisateurs/' + utilisateur.id + '?_method=PUT' : '/admin/utilisateurs' %>"
                  method="POST" enctype="multipart/form-data">

                <div class="mb-4 text-center">
                    <% if (utilisateur && utilisateur.photo) { %>
                        <img src="<%= utilisateur.photo %>"
                             style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:4px solid #16a34a;"
                             class="mb-3 d-block mx-auto">
                    <% } else { %>
                        <div style="width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,#16a34a,#064e3b);display:flex;align-items:center;justify-content:center;margin:0 auto 15px;">
                            <i class="bi bi-person-fill text-white" style="font-size:3rem;"></i>
                        </div>
                    <% } %>
                    <label class="form-label fw-semibold d-block">Photo de profil</label>
                    <input type="file" name="photo" class="form-control" accept="image/*">
                    <small class="text-muted">Formats : JPG, PNG — Max 5MB</small>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nom *</label>
                        <input type="text" name="nom" class="form-control" value="<%= utilisateur ? utilisateur.nom : '' %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Prénom *</label>
                        <input type="text" name="prenom" class="form-control" value="<%= utilisateur ? utilisateur.prenom : '' %>" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email *</label>
                        <input type="email" name="email" class="form-control" value="<%= utilisateur ? utilisateur.email : '' %>" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Téléphone</label>
                        <input type="tel" name="telephone" class="form-control" placeholder="Ex: 77 000 00 00"
                               value="<%= utilisateur ? utilisateur.telephone || '' : '' %>">
                    </div>
                    <% if (!utilisateur) { %>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Mot de passe *</label>
                        <input type="password" name="mot_de_passe" class="form-control" placeholder="Minimum 6 caractères" required>
                    </div>
                    <% } %>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Rôle *</label>
                        <select name="role" class="form-select" required>
                            <option value="">-- Choisir un rôle --</option>
                            <% ['administrateur','gestionnaire_catalogue','gestionnaire_stock','fournisseur','vendeur'].forEach(r => { %>
                                <option value="<%= r %>" <%= utilisateur && utilisateur.role === r ? 'selected' : '' %>><%= r.replace(/_/g,' ') %></option>
                            <% }) %>
                        </select>
                    </div>
                    <% if (utilisateur) { %>
                    <div class="col-md-6 d-flex align-items-end pb-1">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="actif" id="actif" <%= utilisateur.actif ? 'checked' : '' %>>
                            <label class="form-check-label fw-semibold" for="actif">Compte actif</label>
                        </div>
                    </div>
                    <% } %>
                    <div class="col-12 mt-3">
                        <button type="submit" class="btn btn-primary px-5 py-2">
                            <i class="bi bi-check-lg me-2"></i><%= utilisateur ? 'Modifier' : 'Créer' %>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
