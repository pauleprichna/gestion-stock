<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-admin') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-people-fill me-2"></i>Gestion des Utilisateurs</h4>
        <a href="/admin/utilisateurs/nouveau" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nouvel Utilisateur
        </a>
    </div>
    <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background:#064e3b; color:white;">
                    <tr>
                        <th class="px-4 py-3">Photo</th>
                        <th>Nom Complet</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Rôle</th>
                        <th>Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                <% utilisateurs.forEach(u => { %>
                    <tr>
                        <td class="px-4">
                            <% if (u.photo) { %>
                                <img src="<%= u.photo %>" style="width:45px;height:45px;border-radius:50%;object-fit:cover;border:2px solid #16a34a;">
                            <% } else { %>
                                <div style="width:45px;height:45px;border-radius:50%;background:linear-gradient(135deg,#16a34a,#064e3b);display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-person-fill text-white"></i>
                                </div>
                            <% } %>
                        </td>
                        <td class="fw-semibold align-middle"><%= u.prenom %> <%= u.nom %></td>
                        <td class="align-middle"><%= u.email %></td>
                        <td class="align-middle"><%= u.telephone || '—' %></td>
                        <td class="align-middle">
                            <% const roleColors = { administrateur:'danger', gestionnaire_catalogue:'warning', gestionnaire_stock:'success', fournisseur:'info', vendeur:'primary' }; %>
                            <span class="badge bg-<%= roleColors[u.role] || 'secondary' %>"><%= u.role.replace(/_/g,' ') %></span>
                        </td>
                        <td class="align-middle">
                            <span class="badge <%= u.actif ? 'bg-success' : 'bg-secondary' %>"><%= u.actif ? 'Actif' : 'Inactif' %></span>
                        </td>
                        <td class="text-center align-middle">
                            <a href="/admin/utilisateurs/<%= u.id %>/modifier" class="btn btn-sm btn-outline-success me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <% if (u.id !== user.id) { %>
                            <form action="/admin/utilisateurs/<%= u.id %>?_method=DELETE" method="POST"
                                  class="d-inline" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
