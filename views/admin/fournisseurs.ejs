<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-admin') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-truck me-2"></i>Fournisseurs</h4>
        <a href="/admin/utilisateurs/nouveau" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nouveau Fournisseur
        </a>
    </div>

    <% if (fournisseurs.length === 0) { %>
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Aucun fournisseur enregistré.</div>
    <% } else { %>
    <div class="row g-4">
        <% fournisseurs.forEach(f => { %>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#0891b2,#0e7490);display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-truck text-white fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold"><%= f.prenom %> <%= f.nom %></h6>
                            <small class="text-muted"><%= f.email %></small>
                        </div>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Téléphone</span>
                        <span><%= f.telephone || '—' %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total commandes</span>
                        <span class="badge bg-secondary"><%= f.nb_commandes %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Commandes livrées</span>
                        <span class="badge bg-success"><%= f.nb_livrees %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Statut</span>
                        <span class="badge <%= f.actif ? 'bg-success' : 'bg-secondary' %>"><%= f.actif ? 'Actif' : 'Inactif' %></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Membre depuis</span>
                        <span><%= new Date(f.date_creation).toLocaleDateString('fr-FR') %></span>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
