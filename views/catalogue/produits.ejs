<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-catalogue') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-box-seam me-2"></i>Produits</h4>
        <a href="/catalogue/produits/nouveau" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nouveau Produit
        </a>
    </div>
    <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background:#064e3b; color:white;">
                    <tr>
                        <th class="px-4 py-3">Nom</th>
                        <th>Catégorie</th>
                        <th>Prix</th>
                        <th>Stock</th>
                        <th>Seuil</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                <% produits.forEach(p => { %>
                    <tr>
                        <td class="px-4 fw-semibold align-middle"><%= p.nom %></td>
                        <td class="align-middle"><span class="badge bg-warning text-dark"><%= p.categorie_nom || 'Non catégorisé' %></span></td>
                        <td class="align-middle"><strong><%= parseFloat(p.prix).toLocaleString('fr-FR') %> FCFA</strong></td>
                        <td class="align-middle"><span class="badge <%= p.quantite_stock <= p.seuil_alerte ? 'bg-danger' : 'bg-success' %>"><%= p.quantite_stock %></span></td>
                        <td class="align-middle"><%= p.seuil_alerte %></td>
                        <td class="text-center align-middle">
                            <a href="/catalogue/produits/<%= p.id %>/modifier" class="btn btn-sm btn-outline-success me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form action="/catalogue/produits/<%= p.id %>?_method=DELETE" method="POST"
                                  class="d-inline" onsubmit="return confirm('Supprimer ce produit ?')">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
