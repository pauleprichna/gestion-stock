<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-catalogue') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-percent me-2"></i>Gestion des Promotions</h4>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalPromo">
            <i class="bi bi-plus-lg me-2"></i>Nouvelle Promotion
        </button>
    </div>
    <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div class="card">
        <div class="card-body p-0">
            <% if (promos.length === 0) { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-percent fs-1 d-block mb-3"></i>
                    Aucune promotion créée.
                </div>
            <% } else { %>
            <table class="table table-hover mb-0">
                <thead style="background:#064e3b; color:white;">
                    <tr>
                        <th class="px-4 py-3">Nom</th>
                        <th>Appliquée sur</th>
                        <th>Réduction</th>
                        <th>Période</th>
                        <th>Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                <% promos.forEach(p => { %>
                    <tr>
                        <td class="px-4 fw-semibold"><%= p.nom %></td>
                        <td>
                            <% if (p.produit_nom) { %>
                                <span class="badge bg-success"><i class="bi bi-box-seam me-1"></i><%= p.produit_nom %></span>
                            <% } else if (p.categorie_nom) { %>
                                <span class="badge bg-warning text-dark"><i class="bi bi-tags me-1"></i><%= p.categorie_nom %></span>
                            <% } else { %>
                                <span class="badge bg-secondary">Tous</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (p.type === 'pourcentage') { %>
                                <span class="badge bg-danger fs-6">-<%= p.valeur %>%</span>
                            <% } else { %>
                                <span class="badge bg-danger fs-6">-<%= parseFloat(p.valeur).toLocaleString('fr-FR') %> FCFA</span>
                            <% } %>
                        </td>
                        <td>
                            <small><%= new Date(p.date_debut).toLocaleDateString('fr-FR') %></small>
                            <i class="bi bi-arrow-right mx-1"></i>
                            <small><%= new Date(p.date_fin).toLocaleDateString('fr-FR') %></small>
                        </td>
                        <td>
                            <% const today = new Date(); const fin = new Date(p.date_fin); %>
                            <% if (!p.actif) { %>
                                <span class="badge bg-secondary">Désactivée</span>
                            <% } else if (fin < today) { %>
                                <span class="badge bg-dark">Expirée</span>
                            <% } else { %>
                                <span class="badge bg-success">Active</span>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <form action="/catalogue/promotions/<%= p.id %>/toggle" method="POST" class="d-inline">
                                <button class="btn btn-sm <%= p.actif ? 'btn-outline-warning' : 'btn-outline-success' %>">
                                    <i class="bi bi-<%= p.actif ? 'pause' : 'play' %>-fill"></i>
                                </button>
                            </form>
                            <form action="/catalogue/promotions/<%= p.id %>?_method=DELETE" method="POST"
                                  class="d-inline" onsubmit="return confirm('Supprimer cette promotion ?')">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>
</div>

<!-- Modal Nouvelle Promotion -->
<div class="modal fade" id="modalPromo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:#064e3b; color:white;">
                <h5 class="modal-title"><i class="bi bi-percent me-2"></i>Nouvelle Promotion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form action="/catalogue/promotions" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nom de la promotion *</label>
                        <input type="text" name="nom" class="form-control" placeholder="Ex: Promo Ramadan" required>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Type *</label>
                            <select name="type" class="form-select" required onchange="toggleType(this)">
                                <option value="pourcentage">Pourcentage (%)</option>
                                <option value="montant">Montant fixe (FCFA)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Valeur *</label>
                            <div class="input-group">
                                <input type="number" name="valeur" class="form-control" min="0" step="0.01" required>
                                <span class="input-group-text" id="type-suffix">%</span>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Appliquer sur un produit</label>
                        <select name="produit_id" class="form-select">
                            <option value="">-- Choisir un produit (optionnel) --</option>
                            <% produits.forEach(p => { %>
                                <option value="<%= p.id %>"><%= p.nom %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">OU appliquer sur une catégorie</label>
                        <select name="categorie_id" class="form-select">
                            <option value="">-- Choisir une catégorie (optionnel) --</option>
                            <% categories.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.nom %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Date début *</label>
                            <input type="date" name="date_debut" class="form-control" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Date fin *</label>
                            <input type="date" name="date_fin" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check me-2"></i>Créer la promotion
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
function toggleType(sel) {
    const suffix = document.getElementById('type-suffix');
    suffix.textContent = sel.value === 'pourcentage' ? '%' : 'FCFA';
}
</script>
</body>
</html>
