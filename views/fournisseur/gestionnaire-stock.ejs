<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-fournisseur') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-person-badge me-2"></i>Gestionnaire(s) de Stock</h4>
    </div>
    <% if (gestionnaires.length === 0) { %>
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Aucun gestionnaire de stock ne vous a encore passé de commande.
        </div>
    <% } else { %>
    <div class="row g-4">
        <% gestionnaires.forEach(g => { %>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body p-4 text-center">
                    <% if (g.photo) { %>
                        <img src="<%= g.photo %>"
                             style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid #16a34a;margin-bottom:12px;">
                    <% } else { %>
                        <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#8b5cf6);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                            <i class="bi bi-person-fill text-white fs-3"></i>
                        </div>
                    <% } %>
                    <h5 class="fw-bold mb-1"><%= g.prenom %> <%= g.nom %></h5>
                    <p class="text-muted small mb-2"><%= g.email %></p>
                    <% if (g.telephone) { %>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-telephone me-1"></i><%= g.telephone %>
                        </p>
                    <% } %>
                    <span class="badge" style="background:#7c3aed;">Gestionnaire Stock</span>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Commandes passées</span>
                        <span class="badge bg-success"><%= g.nb_commandes_passees %></span>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
