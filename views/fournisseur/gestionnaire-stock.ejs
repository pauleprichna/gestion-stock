<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-fournisseur') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-person-badge me-2"></i>Gestionnaire(s) de Stock</h4>
    </div>
    <% if (gestionnaires.length === 0) { %>
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>Aucun gestionnaire de stock disponible.
        </div>
    <% } else { %>
    <div class="row g-4">
        <% gestionnaires.forEach(g => { %>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body p-4 text-center">
                    <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#8b5cf6);display:flex;align-items:center;justify-content:center;margin:0 auto 15px;">
                        <i class="bi bi-person-fill text-white fs-3"></i>
                    </div>
                    <h5 class="fw-bold"><%= g.prenom %> <%= g.nom %></h5>
                    <p class="text-muted"><%= g.email %></p>
                    <span class="badge" style="background:#7c3aed;">Gestionnaire Stock</span>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
