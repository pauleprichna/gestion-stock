<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-vendeur') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-shop me-2"></i>Tableau de bord — Vendeur</h4>
        <span class="badge" style="background:#b45309; padding:8px 15px; border-radius:20px;">
            <i class="bi bi-cash-coin me-1"></i>Vendeur
        </span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#16a34a,#15803d);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.ventesAujourd || 0 %></div><div>Ventes aujourd'hui</div></div>
                    <i class="bi bi-bag-check-fill stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number" style="font-size:1.4rem"><%= stats.caAujourd || 0 %></div><div>CA aujourd'hui (FCFA)</div></div>
                    <i class="bi bi-cash-stack stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.ventesTotal || 0 %></div><div>Total ventes</div></div>
                    <i class="bi bi-receipt stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#0891b2,#0e7490);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number" style="font-size:1.4rem"><%= stats.caTotal || 0 %></div><div>CA total (FCFA)</div></div>
                    <i class="bi bi-graph-up-arrow stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header" style="background:#064e3b; color:white;">
            <i class="bi bi-lightning-charge-fill me-2"></i>Actions rapides
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <a href="/vendeur/nouvelle-vente" class="btn w-100 py-4 text-white fw-bold" style="background:linear-gradient(135deg,#16a34a,#064e3b); border-radius:12px;">
                        <i class="bi bi-cart-plus-fill d-block fs-2 mb-2"></i>Nouvelle Vente en Espèces
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="/vendeur/historique" class="btn btn-outline-secondary w-100 py-4" style="border-radius:12px;">
                        <i class="bi bi-clock-history d-block fs-2 mb-2"></i>Voir l'historique
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
