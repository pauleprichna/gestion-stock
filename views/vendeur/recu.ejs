<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %>
<style>
    @media print {
        .sidebar, .topbar, .no-print { display:none !important; }
        .main-content { margin-left:0 !important; padding:10px !important; }
        .recu-card { box-shadow:none !important; border:1px solid #ddd !important; }
    }
    .recu-card { max-width:550px; margin:0 auto; }
    .recu-header { background:linear-gradient(135deg,#064e3b,#16a34a); color:white; border-radius:12px 12px 0 0; padding:25px; text-align:center; }
    .recu-body { background:white; padding:25px; border:1px solid #e5e7eb; }
    .recu-footer { background:#f0fdf4; border-radius:0 0 12px 12px; padding:20px 25px; border:1px solid #e5e7eb; border-top:none; }
    .ligne-item { border-bottom:1px dashed #e5e7eb; padding:10px 0; }
    .total-box { background:#064e3b; color:white; border-radius:10px; padding:15px 20px; }
    .monnaie-box { background:#fef3c7; border-radius:10px; padding:12px 20px; border:1px solid #fbbf24; }
</style>
</head>
<body>
<%- include('../partials/navbar-vendeur') %>
<div class="main-content">
    <div class="topbar no-print">
        <h4><i class="bi bi-receipt me-2"></i>Reçu de Vente</h4>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-success"><i class="bi bi-printer me-2"></i>Imprimer</button>
            <a href="/vendeur/nouvelle-vente" class="btn btn-primary"><i class="bi bi-cart-plus me-2"></i>Nouvelle vente</a>
            <a href="/vendeur/historique" class="btn btn-outline-secondary"><i class="bi bi-clock-history me-2"></i>Historique</a>
        </div>
    </div>

    <div class="recu-card card">
        <div class="recu-header">
            <i class="bi bi-shop d-block fs-1 mb-2"></i>
            <h4 class="mb-1 fw-bold">Fresh Market</h4>
            <p class="mb-0 opacity-75">Reçu de vente en espèces</p>
        </div>
        <div class="recu-body">
            <div class="d-flex justify-content-between mb-3">
                <div>
                    <div class="text-muted small">Référence</div>
                    <div class="fw-bold"><%= vente.reference %></div>
                </div>
                <div class="text-end">
                    <div class="text-muted small">Date & Heure</div>
                    <div class="fw-bold"><%= new Date(vente.date_vente).toLocaleString('fr-FR') %></div>
                </div>
            </div>
            <div class="mb-3">
                <div class="text-muted small">Vendeur</div>
                <div class="fw-bold"><%= vente.vendeur_prenom %> <%= vente.vendeur_nom %></div>
            </div>
            <hr>
            <h6 class="fw-bold mb-3">Articles vendus :</h6>
            <% lignes.forEach(l => { %>
            <div class="ligne-item">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold"><%= l.produit_nom %></div>
                        <small class="text-muted"><%= l.quantite %> × <%= parseFloat(l.prix_unitaire).toLocaleString('fr-FR') %> FCFA</small>
                    </div>
                    <div class="fw-bold text-success"><%= parseFloat(l.sous_total).toLocaleString('fr-FR') %> FCFA</div>
                </div>
            </div>
            <% }) %>
        </div>
        <div class="recu-footer">
            <div class="total-box mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fs-5">TOTAL</span>
                    <span class="fs-4 fw-bold"><%= parseFloat(vente.montant_total).toLocaleString('fr-FR') %> FCFA</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-1 opacity-75">
                    <span>Reçu</span>
                    <span><%= parseFloat(vente.montant_recu).toLocaleString('fr-FR') %> FCFA</span>
                </div>
            </div>
            <div class="monnaie-box">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold text-amber-700">💰 Monnaie rendue</span>
                    <span class="fw-bold fs-5" style="color:#92400e;"><%= parseFloat(vente.monnaie_rendue).toLocaleString('fr-FR') %> FCFA</span>
                </div>
            </div>
            <div class="text-center mt-3 text-muted small">
                <i class="bi bi-check-circle-fill text-success me-1"></i>
                Merci pour votre achat !
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
