<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-stock') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-clock-history me-2"></i>Historique de mes Ventes</h4>
        <a href="/stock/nouvelle-vente" class="btn btn-primary"><i class="bi bi-plus-lg me-2"></i>Nouvelle vente</a>
    </div>

    <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div class="card">
        <div class="card-body p-0">
            <% if (ventes.length === 0) { %>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    Aucune vente enregistrée pour le moment.
                </div>
            <% } else { %>
            <table class="table table-hover mb-0">
                <thead style="background:#064e3b; color:white;">
                    <tr>
                        <th class="px-4 py-3">Référence</th>
                        <th>Articles</th>
                        <th>Montant total</th>
                        <th>Reçu</th>
                        <th>Monnaie rendue</th>
                        <th>Date</th>
                        <th class="text-center">Reçu</th>
                    </tr>
                </thead>
                <tbody>
                <% ventes.forEach(v => { %>
                    <tr>
                        <td class="px-4 fw-semibold"><%= v.reference %></td>
                        <td><span class="badge bg-secondary"><%= v.nb_articles %> article(s)</span></td>
                        <td><strong class="text-success"><%= parseFloat(v.montant_total).toLocaleString('fr-FR') %> FCFA</strong></td>
                        <td><%= parseFloat(v.montant_recu).toLocaleString('fr-FR') %> FCFA</td>
                        <td><span class="badge bg-warning text-dark"><%= parseFloat(v.monnaie_rendue).toLocaleString('fr-FR') %> FCFA</span></td>
                        <td><%= new Date(v.date_vente).toLocaleString('fr-FR') %></td>
                        <td class="text-center">
                            <a href="/stock/recu/<%= v.id %>" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-printer"></i>
                            </a>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
