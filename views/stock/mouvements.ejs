<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-stock') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-arrow-left-right me-2"></i>Mouvements de Stock</h4>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalMouvement"><i class="bi bi-plus-lg me-2"></i>Nouveau Mouvement</button>
    </div>
    <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background:#064e3b; color:white;">
                    <tr><th class="px-4 py-3">Produit</th><th>Type</th><th>Quantité</th><th>Motif</th><th>Effectué par</th><th>Date</th></tr>
                </thead>
                <tbody>
                <% mouvements.forEach(m => { %>
                    <tr>
                        <td class="px-4 fw-semibold"><%= m.produit_nom %></td>
                        <td><span class="badge <%= m.type === 'entree' ? 'bg-success' : 'bg-danger' %>"><i class="bi bi-arrow-<%= m.type === 'entree' ? 'down' : 'up' %>-circle me-1"></i><%= m.type %></span></td>
                        <td><strong><%= m.quantite %></strong></td>
                        <td><%= m.motif || '—' %></td>
                        <td><%= m.user_prenom ? m.user_prenom + ' ' + m.user_nom : '—' %></td>
                        <td><%= new Date(m.date_mouvement).toLocaleString('fr-FR') %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<!-- Modal Mouvement -->
<div class="modal fade" id="modalMouvement" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:#064e3b; color:white;">
                <h5 class="modal-title"><i class="bi bi-arrow-left-right me-2"></i>Nouveau Mouvement</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form action="/stock/mouvements" method="POST">
                    <div class="mb-3"><label class="form-label fw-semibold">Produit *</label>
                        <select name="produit_id" class="form-select" required>
                            <option value="">-- Choisir un produit --</option>
                            <% produits.forEach(p => { %><option value="<%= p.id %>"><%= p.nom %> (stock: <%= p.quantite_stock %>)</option><% }) %>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label fw-semibold">Type *</label>
                        <select name="type" class="form-select" required>
                            <option value="entree"> Entrée de stock</option>
                            <option value="sortie"> Sortie de stock</option>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label fw-semibold">Quantité *</label><input type="number" name="quantite" class="form-control" min="1" required></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Motif</label><textarea name="motif" class="form-control" rows="2"></textarea></div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check me-2"></i>Enregistrer</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
