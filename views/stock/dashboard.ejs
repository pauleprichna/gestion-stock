<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-stock') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-speedometer2 me-2"></i>Tableau de bord — Gestionnaire Stock</h4>
        <span class="badge" style="background:#7c3aed; padding:8px 15px; border-radius:20px;"><i class="bi bi-archive me-1"></i>Gestionnaire Stock</span>
    </div>

    <p class="text-muted fw-semibold mb-2"><i class="bi bi-boxes me-2"></i>Stock</p>
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#16a34a,#15803d);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.produits || 0 %></div><div>Produits en stock</div></div>
                    <i class="bi bi-box-seam stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#dc2626,#b91c1c);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.alertes || 0 %></div><div>Alertes stock bas</div></div>
                    <i class="bi bi-exclamation-triangle-fill stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.mouvements || 0 %></div><div>Mouvements</div></div>
                    <i class="bi bi-arrow-left-right stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#0891b2,#0e7490);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.commandes || 0 %></div><div>Commandes actives</div></div>
                    <i class="bi bi-cart-fill stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <p class="text-muted fw-semibold mb-2"><i class="bi bi-cash-coin me-2"></i>Ventes en espèces</p>
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="stat-card" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.ventesAujourd || 0 %></div><div>Ventes aujourd'hui</div></div>
                    <i class="bi bi-bag-check-fill stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="stat-card" style="background:linear-gradient(135deg,#db2777,#be185d);">
                <div class="d-flex justify-content-between align-items-start">
                    <div><div class="stat-number"><%= stats.ventesTotal || 0 %></div><div>Total ventes</div></div>
                    <i class="bi bi-receipt stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header" style="background:#064e3b; color:white;">
            <i class="bi bi-lightning-charge-fill me-2"></i>Accès rapides
        </div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-2">
                    <a href="/stock/voir-stock" class="btn btn-outline-success w-100 py-3">
                        <i class="bi bi-eye-fill d-block fs-3 mb-2"></i>Voir le stock</a>
                </div>
                <div class="col-md-2">
                    <a href="/stock/mouvements" class="btn w-100 py-3" style="border:1px solid #7c3aed; color:#7c3aed;">
                        <i class="bi bi-arrow-left-right d-block fs-3 mb-2"></i>Entrée / Sortie</a>
                </div>
                <div class="col-md-2">
                    <a href="/stock/commandes" class="btn btn-outline-warning w-100 py-3">
                        <i class="bi bi-cart-fill d-block fs-3 mb-2"></i>Commandes appro</a>
                </div>

                <div class="col-md-2">
                    <a href="/stock/alertes" class="btn btn-outline-danger w-100 py-3">
                        <i class="bi bi-exclamation-triangle-fill d-block fs-3 mb-2"></i>Alertes</a>
                </div>
                <div class="col-md-2">
                    <a href="/stock/rapport" class="btn btn-outline-secondary w-100 py-3">
                        <i class="bi bi-file-earmark-bar-graph-fill d-block fs-3 mb-2"></i>Rapport</a>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
