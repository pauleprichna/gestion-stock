<!DOCTYPE html>
<html lang="fr">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/navbar-stock') %>
<div class="main-content">
    <div class="topbar">
        <h4><i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i>Alertes Stock</h4>
    </div>
    <% if (produits.length === 0) { %>
        <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>Aucune alerte. Tous les stocks sont suffisants !</div>
    <% } else { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong><%= produits.length %> produit(s)</strong> ont un stock inférieur ou égal au seuil d'alerte.</div>
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background:#dc2626; color:white;">
                    <tr><th class="px-4 py-3">Produit</th><th>Catégorie</th><th>Stock actuel</th><th>Seuil alerte</th><th>Statut</th></tr>
                </thead>
                <tbody>
                <% produits.forEach(p => { %>
                    <tr>
                        <td class="px-4 fw-semibold"><%= p.nom %></td>
                        <td><%= p.categorie_nom || '—' %></td>
                        <td><span class="badge bg-danger fs-6"><%= p.quantite_stock %></span></td>
                        <td><%= p.seuil_alerte %></td>
                        <td><%-  p.quantite_stock === 0 ? '<span class="badge bg-dark">Rupture totale</span>' : '<span class="badge bg-warning text-dark">Stock critique</span>' %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
